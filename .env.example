# Copy this file to .env and fill in your values

# Database path (SQLite)
DATABASE_URL=parking_matching.db

# API endpoints for each parking provider

# ParkWhiz API configuration 
PARKWHIZ_BASE_URL=your_parkwhiz_api_base_url_here
PARKWHIZ_API_TOKEN=your_parkwhiz_api_token_here
PARKWHIZ_USE_MOCK_FALLBACK=true

# SpotHero API configuration 
SPOTHERO_BASE_URL=your_spothero_api_base_url_here
SPOTHERO_API_TOKEN=your_spothero_api_token_here
SPOTHERO_USE_MOCK_FALLBACK=true

# Cheap Airport Parking API configuration 
CHEAP_AIRPORT_PARKING_BASE_URL=your_cap_api_base_url_here
CHEAP_AIRPORT_PARKING_API_TOKEN=your_cap_api_token_here
CHEAP_AIRPORT_PARKING_USE_MOCK_FALLBACK=true
